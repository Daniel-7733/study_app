# =========================
# Python cache / compiled files
# =========================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Environment / secrets
# =========================
.env
.env.*
!.env.example

# =========================
# SQLite database files
# Keep the folder, ignore local database files
# =========================
data/*.db
data/*.sqlite
data/*.sqlite3

# Keep empty data folder in Git
!data/.gitkeep

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# Test / coverage output
# =========================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# =========================
# Build / packaging output
# =========================
build/
dist/
*.egg-info/
.eggs/
*.egg

# =========================
# Type checker / linter cache
# =========================
.mypy_cache/
.ruff_cache/
.pyre/

# =========================
# IDE / editor settings
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Temporary files
# =========================
*.tmp
*.bak
*.old
